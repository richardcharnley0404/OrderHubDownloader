{
  "name": "orderhub-downloader",
  "version": "0.1.2",
  "description": "Automatic FTP file downloader for OrderHub jobs",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:dir": "electron-builder --dir",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "keywords": [
    "electron",
    "orderhub",
    "ftp",
    "downloader"
  ],
  "author": "Pixfizz Ltd",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "basic-ftp": "^5.0.0",
    "chokidar": "^5.0.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.0",
    "fast-xml-parser": "^5.4.1",
    "mime-types": "^2.1.35",
    "uuid": "^13.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
    "fast-xml-parser": "^5.4.1"
  },
  "build": {
    "appId": "com.pixfizz.orderhub-downloader",
    "productName": "OrderHub Downloader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
